NODE_ENV=development
BIND_HOST=127.0.0.1
PORT=4300
POSTGRES_OWNER_PASSWORD=replace-with-a-long-random-owner-password
CI_DOCTOR_APP_PASSWORD=replace-with-a-long-random-app-password
DATABASE_URL=postgresql://ci_doctor_app:replace-with-a-long-random-app-password@127.0.0.1:5432/ci_doctor
GITHUB_WEBHOOK_SECRET=replace-with-a-32-byte-random-secret
GITHUB_ALLOWED_REPOSITORIES=your-github-owner/ci-doctor-fixtures
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-this-with-your-github-app-private-key\n-----END PRIVATE KEY-----"
ARTIFACT_ENCRYPTION_KEY_BASE64=replace-with-a-base64-encoded-32-byte-key
OPENAI_API_KEY=replace-with-project-scoped-openai-api-key
OPENAI_DIAGNOSIS_MODEL=gpt-5.6
DIAGNOSIS_WORKER_CONCURRENCY=3
LOG_LEVEL=info
