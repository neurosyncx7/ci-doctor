{
  "name": "ci-doctor",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-backed, sandbox-validated remediation for failed CI runs.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:api": "node --env-file=.env --import tsx --watch apps/api/src/server.ts",
    "start:api": "node --enable-source-maps apps/api/dist/server.js",
    "build:api": "tsc --project apps/api/tsconfig.json",
    "test:api": "node --import tsx --test apps/api/test/github-webhook.test.ts apps/api/test/log-redaction.test.ts apps/api/test/failure-clustering.test.ts apps/api/test/diagnosis-contract.test.ts apps/api/test/repair-policy.test.ts apps/api/test/repair-attempt-loop.test.ts apps/api/test/docker-sandbox.integration.test.ts",
    "test:docker": "node --env-file=.env --import tsx --test apps/api/test/docker-sandbox.integration.test.ts",
    "worker:ingest": "node --env-file=.env --import tsx apps/api/src/workers/ingest-server.ts",
    "worker:diagnose": "node --env-file=.env --import tsx apps/api/src/workers/diagnosis-server.ts",
    "test:fixture": "npm.cmd --prefix fixtures/ci-doctor-fixtures test",
    "db:up": "docker compose --env-file .env --file infra/postgres/compose.yml up -d",
    "db:down": "docker compose --env-file .env --file infra/postgres/compose.yml down",
    "db:migrate": "node --env-file=.env --import tsx apps/api/src/persistence/migrate.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.1.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.2.1",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
