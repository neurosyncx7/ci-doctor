{
  "name": "ci-doctor",
  "version": "0.1.0",
  "private": true,
  "description": "Evidence-backed, sandbox-validated remediation for failed CI runs.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:api": "node --env-file=.env --import tsx --watch apps/api/src/server.ts",
    "dev:console": "concurrently --names api,console --prefix-colors cyan,magenta \"npm run dev:api\" \"npm run dev:dashboard\"",
    "start:api": "node --enable-source-maps apps/api/dist/server.js",
    "build:api": "tsc --project apps/api/tsconfig.json",
    "dev:dashboard": "vite --config apps/dashboard/vite.config.ts",
    "build:dashboard": "vite build --config apps/dashboard/vite.config.ts",
    "benchmark:run": "node --import tsx benchmarks/src/run.ts",
    "benchmark:report": "node --import tsx benchmarks/src/report.ts",
    "test:api": "node --import tsx --test apps/api/test/github-webhook.test.ts apps/api/test/github-pr-broker.test.ts apps/api/test/log-redaction.test.ts apps/api/test/failure-clustering.test.ts apps/api/test/diagnosis-contract.test.ts apps/api/test/repair-policy.test.ts apps/api/test/repair-attempt-loop.test.ts apps/api/test/structured-patch.test.ts apps/api/test/docker-sandbox.integration.test.ts",
    "test:docker": "node --env-file=.env --import tsx --test apps/api/test/docker-sandbox.integration.test.ts",
    "worker:ingest": "node --env-file=.env --import tsx apps/api/src/workers/ingest-server.ts",
    "worker:diagnose": "node --env-file=.env --import tsx apps/api/src/workers/diagnosis-server.ts",
    "worker:repair": "node --env-file=.env --import tsx apps/api/src/workers/repair-server.ts",
    "test:fixture": "npm.cmd --prefix fixtures/ci-doctor-fixtures test",
    "db:up": "docker compose --env-file .env --file infra/postgres/compose.yml up -d",
    "db:down": "docker compose --env-file .env --file infra/postgres/compose.yml down",
    "db:migrate": "node --env-file=.env --import tsx apps/api/src/persistence/migrate.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@octokit/auth-app": "^8.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@splinetool/react-spline": "^4.1.0",
    "fastify": "^5.2.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.5"
  }
}
